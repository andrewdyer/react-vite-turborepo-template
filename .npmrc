# GitHub Packages configuration.

# Packages in the @your-github-org scope are resolved from GitHub Packages.
# This file contains no credentials and is safe to commit.

@your-github-org:registry=https://npm.pkg.github.com

# Set your GitHub token for authentication:
#   export NODE_AUTH_TOKEN=your_github_token_here

# ⚠️ WARNING: NEVER COMMIT ACCESS TOKENS TO VERSION CONTROL.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}